{
  "version": 2,
  "builds": [
    {
      "src": "src/server/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/bookmyshow/(.*)",
      "dest": "/src/server/app.js"
    },
    {
      "src": "/",
      "dest": "/src/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/src/public/$1"
    }
  ]
}
